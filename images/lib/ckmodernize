#!/bin/bash
#
# ckmodernize — one-command modernization for a CiviCRM extension, via the
# civikitchen-bundled tools. The extension carries NOTHING: civikitchen
# provides everything, so you can modernize/upgrade any extension *through* the
# image. It orchestrates two layers, each with the right tool:
#
#   1. STRUCTURE — civix (the official scaffolding migrator):
#        civix upgrade          old hook boilerplate -> mixins, info.xml format,
#                               regenerated glue (version-incremental)
#        civix convert-entity   legacy XML entity declarations -> entityType.php
#   2. CODE — rector: off-the-shelf PHP-version + quality sets PLUS CiviKitchen's
#        CiviCRM footgun rules (the deprecations cklint flags).
#
# api3 -> apiv4 and other semantic deprecations are NOT auto-rewritten by anyone
# (APIv4 is a deliberate breaking change) — cklint flags those for a human.
#
# Pairs with cklint:   cklint flags  ->  ckmodernize fixes what's mechanical.
# A project's own rector.php wins for the code step when present.
#
set -uo pipefail

RECTOR_DIR=/opt/civikitchen-rector
RECTOR_BIN="${RECTOR_DIR}/vendor/bin/rector"
DEFAULT_CONFIG="${RECTOR_DIR}/rector.php"

usage() {
  cat <<'EOF'
ckmodernize — modernize a CiviCRM extension (structure via civix + code via rector).

  ckmodernize                preview the code changes (dry-run); list the civix steps
  ckmodernize --fix          apply: civix structure upgrade + rector code rewrite
  ckmodernize --php 8.2      target PHP version for rector's upgrade sets (default 8.1)
  ckmodernize --no-civix     code only (skip the civix structure step)
  ckmodernize --no-rector    structure only (skip the rector code step)
  ckmodernize path ...       limit the rector step to the given files/dirs
  ckmodernize --all          run rector over the whole tree

Run from the extension root. civix steps run only for a civix extension (an
info.xml with a <civix> block) and only on --fix (civix has no preview mode).
EOF
}

fix=0
all=0
do_civix=1
do_rector=1
paths=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --fix|-f)    fix=1 ;;
    --all)       all=1 ;;
    --no-civix)  do_civix=0 ;;
    --no-rector) do_rector=0 ;;
    --php)       shift; export CK_PHP_VERSION="${1:-}" ;;
    --php=*)     export CK_PHP_VERSION="${1#--php=}" ;;
    -h|--help)   usage; exit 0 ;;
    --)          shift; break ;;
    -*)          echo "ckmodernize: unknown option: $1" >&2; usage >&2; exit 2 ;;
    *)           paths+=("$1") ;;
  esac
  shift
done
while [ "$#" -gt 0 ]; do paths+=("$1"); shift; done

# -------------------------------------------------------------------------
# 1. Structure — civix (writes; civix has no dry-run, so we only run it on --fix
#    and otherwise just announce the plan).
if [ "${do_civix}" -eq 1 ] && [ -f info.xml ] && grep -q '<civix>' info.xml; then
  if [ "${fix}" -eq 1 ]; then
    echo "== civix: modernizing scaffolding =="
    civix upgrade -n || echo "ckmodernize: civix upgrade reported issues (continuing)" >&2
    civix convert-entity -n 2>/dev/null || true
  else
    echo "== civix (structure): on --fix this runs 'civix upgrade' + 'civix convert-entity' (civix has no preview) =="
  fi
fi

# -------------------------------------------------------------------------
# 2. Code — rector (dry-run preview by default).
if [ "${do_rector}" -eq 1 ]; then
  echo "== rector: modernizing code =="

  if [ "${all}" -eq 1 ]; then
    paths=(".")
  elif [ "${#paths[@]}" -eq 0 ]; then
    for d in Civi CRM api; do [ -d "$d" ] && paths+=("$d"); done
    while IFS= read -r f; do [ -n "$f" ] && paths+=("$f"); done \
      < <(find . -maxdepth 1 -name '*.php' -type f 2>/dev/null)
    [ "${#paths[@]}" -eq 0 ] && paths=(".")
  fi

  # A project's own rector.php wins; otherwise the bundled CiviKitchen config.
  config=("--config" "${DEFAULT_CONFIG}")
  [ -f rector.php ] && config=()

  rargs=(process "${paths[@]}" "${config[@]}" --no-progress-bar)
  [ "${fix}" -eq 0 ] && rargs+=(--dry-run)
  php -d memory_limit=1G "${RECTOR_BIN}" "${rargs[@]}"
fi
