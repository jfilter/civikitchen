#!/bin/bash
#
# ckconform — thin shim onto the PHP implementation in /opt/civikitchen-ckconform.
#
# The checks used to live in this file as shell. They were rewritten in PHP after
# a run of bugs that were all the same bug: parsing structured formats with
# line-oriented text tools. A `<license>` spanning two lines read as empty, an
# `<ext version="3.32">` was invisible to a tag-shaped regex, a nested `"license"`
# key in composer.json won over the real one, `ang/afform/*.aff.html` fell through
# a fixed-depth glob, and an @since parse using sed's \+ silently returned nothing
# on BSD sed — so that check passed on everything instead of failing.
#
# The port is verified byte-identical against the shell version across all
# consuming repos, and every check now carries fixture tests (149 of them), which
# the shell version never had.
set -uo pipefail

for candidate in /opt/civikitchen-ckconform "$(dirname "${BASH_SOURCE[0]}")/../ckconform"; do
  if [ -x "$candidate/bin/ckconform" ]; then
    exec php "$candidate/bin/ckconform" "$@"
  fi
done

echo "ckconform: cannot find the implementation (expected /opt/civikitchen-ckconform)" >&2
exit 2
