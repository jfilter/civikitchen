#!/bin/bash
#
# ckconform — repo-conformance check for CiviCRM extensions against the
# civikitchen template (template/extension/). Complements cklint (code style)
# and phpstan (types): this checks the REPO STRUCTURE — the gaps that showed
# up in every extension audit. Run from the extension root.
#
# Checks (each is a FAIL unless noted):
#   - phpcs.xml.dist referencing the CiviKitchen standard
#   - phpstan.neon.dist at level 10, no blanket ignores (warn), no baseline
#   - phpunit.xml.dist present when tests/phpunit exists
#   - tests/phpunit/bootstrap.php contains the TEST_DB_DSN guard
#   - composer.json present
#   - CI workflow present (.github/workflows/*.yml)
#   - no committed build/cache artifacts (.phpunit.result.cache, node_modules)
#
set -uo pipefail

fails=0
warns=0
fail() { echo "FAIL $1"; fails=$((fails + 1)); }
warn() { echo "warn $1"; warns=$((warns + 1)); }
ok()   { echo "ok   $1"; }

[ -f info.xml ] || { echo "ckconform: no info.xml here — run from the extension root." >&2; exit 2; }

# phpcs project layer
if [ -f phpcs.xml.dist ] || [ -f phpcs.xml ]; then
  if grep -q 'ref="CiviKitchen"' phpcs.xml.dist phpcs.xml 2>/dev/null; then
    ok "phpcs config references the CiviKitchen standard"
  else
    fail "phpcs config exists but does not <rule ref=\"CiviKitchen\"/>"
  fi
else
  fail "no phpcs.xml.dist (cklint has no project anchor)"
fi

# phpstan
if [ -f phpstan.neon.dist ] || [ -f phpstan.neon ]; then
  [ -f phpstan.neon.dist ] || warn "phpstan.neon should be phpstan.neon.dist (local overrides stay untracked)"
  stan=$(cat phpstan.neon.dist phpstan.neon 2>/dev/null)
  if echo "$stan" | grep -qE 'level:\s*(10|max)'; then
    ok "phpstan at level 10"
  else
    fail "phpstan below level 10 (template: level 10, no baseline)"
  fi
  echo "$stan" | grep -qE 'class\.notFound|function\.notFound' \
    && warn "phpstan has blanket notFound ignores — use the bootstrap instead"
  ls phpstan-baseline* >/dev/null 2>&1 && fail "phpstan baseline file present (template: none)"
else
  fail "no phpstan.neon.dist"
fi

# phpunit + bootstrap guard
if [ -d tests/phpunit ]; then
  [ -f phpunit.xml.dist ] || fail "tests/phpunit exists but no phpunit.xml.dist"
  if [ -f tests/phpunit/bootstrap.php ]; then
    # Only Civi\Test rebuilds the database, so only a suite that uses it can
    # wipe the dev data. A pure unit suite (plain TestCase, no CiviCRM boot)
    # has nothing to guard, and demanding the guard there would just be noise.
    if grep -rqE 'HeadlessInterface|TransactionalInterface|Civi\\Test\\' tests 2>/dev/null; then
      if grep -q 'TEST_DB_DSN' tests/phpunit/bootstrap.php; then
        ok "test bootstrap has the TEST_DB_DSN guard"
      else
        fail "tests/phpunit/bootstrap.php lacks the TEST_DB_DSN guard — headless runs can wipe the dev DB"
      fi
    else
      ok "unit-only suite (no Civi\\Test) — no test-database guard needed"
    fi
  else
    fail "no tests/phpunit/bootstrap.php"
  fi

  # Coverage has to be measurable before it can be demanded: without a
  # <coverage> section `phpunit --coverage-text` reports on nothing, which
  # reads like a passing gate.
  if grep -q '<coverage' phpunit.xml.dist phpunit.xml 2>/dev/null; then
    ok "phpunit config declares coverage sources"
  else
    fail "phpunit config has no <coverage> section — coverage runs measure nothing"
  fi
  if ls .github/workflows/*.yml >/dev/null 2>&1 \
    && ! grep -q 'coverage\|ckcoverage' .github/workflows/*.yml 2>/dev/null; then
    warn "CI runs tests without coverage — add ckcoverage (or phpunit --coverage-text)"
  fi
else
  # A repo with real PHP logic and no suite is a gap, not a style preference.
  # Config-only extensions can say so in .ckconform: tests=optional -- <reason>
  optout=$(sed -n 's/^tests=//p' .ckconform 2>/dev/null | head -1)
  # Count the real source surface: Civi/, CRM/ AND the extension's own root
  # .php file, where a config-only extension keeps all of its logic.
  phpfiles=$(
    { find Civi CRM -name '*.php' 2>/dev/null; ls ./*.php 2>/dev/null; } \
      | grep -vE '\.civix\.php|/DAO/|/BAO/|phpstanBootstrap\.php' | wc -l | tr -d ' '
  )
  if [ -n "$optout" ]; then
    ok "no test suite — declared optional in .ckconform ($optout)"
  elif [ "${phpfiles:-0}" -gt 0 ]; then
    fail "no test suite (tests/phpunit) but $phpfiles PHP source file(s) — add tests, or declare 'tests=optional -- <reason>' in .ckconform"
  else
    ok "no test suite — no PHP source to cover"
  fi
fi

# metadata + CI
[ -f composer.json ] || fail "no composer.json (extension metadata)"
if ls .github/workflows/*.yml >/dev/null 2>&1; then
  ok "CI workflow present"
  grep -ql 'cklint\|phpcs' .github/workflows/*.yml || warn "CI has no lint step (cklint/phpcs)"
else
  fail "no CI workflow (.github/workflows/)"
fi

# declared dependencies vs. what the code actually uses. A missing <ext> only
# bites on a fresh site (the extension installs, then fatals on a SearchKit
# entity that isn't there), so nothing catches it during normal development.
extkey=$(sed -n 's/.*<extension[^>]*key="\([^"]*\)".*/\1/p' info.xml | head -1)
requires=$(tr -d '\n' < info.xml | sed -n 's/.*<requires>\(.*\)<\/requires>.*/\1/p')
needs_ext() { # needs_ext <ext-key> <human reason>
  echo "$requires" | grep -q "$1" \
    || fail "info.xml does not <requires> $1 — $2"
}
# -r/find rather than a shallow glob: repos nest these (ang/afform/*.aff.html).
grep -rlq "'SavedSearch'\|'SearchDisplay'" managed 2>/dev/null \
  && needs_ext org.civicrm.search_kit "managed/ ships SavedSearch/SearchDisplay entities"
[ -n "$(find ang -name '*.aff.html' -o -name '*.aff.json' 2>/dev/null | head -1)" ] \
  && needs_ext org.civicrm.afform "ang/ ships Afforms"
grep -rlq "extends CRM_Civirules_\|extends CRM_CivirulesActions_" . --include='*.php' 2>/dev/null \
  && needs_ext org.civicoop.civirules "PHP extends CiviRules base classes"

# LICENSE.txt scaffolding leftovers: civix writes the key of whatever extension
# the file was copied from, and a FIXME copyright holder.
if [ -f LICENSE.txt ]; then
  pkg=$(sed -n 's/^Package: *//p' LICENSE.txt | head -1)
  [ -n "$pkg" ] && [ -n "$extkey" ] && [ "$pkg" != "$extkey" ] \
    && fail "LICENSE.txt says 'Package: $pkg' but info.xml key is '$extkey' (copied skeleton)"
  grep -q FIXME LICENSE.txt && warn "LICENSE.txt still contains FIXME (copyright holder unfilled)"
fi

# Licence coherence. Three files declare it — info.xml, composer.json,
# package.json — and they drift apart silently; a repo can end up publishing
# itself under terms its LICENSE file never granted.
#
# WHICH licence is organisation policy, not this tool's business, so the
# expected values are read from an optional `.ckconform` in the extension
# root (KEY=VALUE, '#' comments). That file lives in your repo, so a private
# policy stays private while the mechanism stays here:
#
#     license=Proprietary          # info.xml <license> + composer.json
#     npm_license=UNLICENSED       # every tracked package.json
#     copyright=Example Ltd        # must appear in LICENSE.txt
#
# Without a `.ckconform` the declarations only have to agree with each other.
lc() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }
lic_xml=$(sed -n 's/.*<license>\(.*\)<\/license>.*/\1/p' info.xml | head -1)
lic_composer=$(sed -n 's/.*"license"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' composer.json 2>/dev/null | head -1)

want_lic=""; want_npm=""; want_copyright=""
if [ -f .ckconform ]; then
  want_lic=$(sed -n 's/^license=//p' .ckconform | head -1)
  want_npm=$(sed -n 's/^npm_license=//p' .ckconform | head -1)
  want_copyright=$(sed -n 's/^copyright=//p' .ckconform | head -1)
fi

if [ -n "$want_lic" ]; then
  [ "$(lc "$lic_xml")" = "$(lc "$want_lic")" ] \
    || fail "info.xml <license> is '${lic_xml:-empty}', .ckconform expects '$want_lic'"
  [ -z "$lic_composer" ] || [ "$(lc "$lic_composer")" = "$(lc "$want_lic")" ] \
    || fail "composer.json license is '$lic_composer', .ckconform expects '$want_lic'"
elif [ -n "$lic_xml" ] && [ -n "$lic_composer" ] && [ "$(lc "$lic_xml")" != "$(lc "$lic_composer")" ]; then
  fail "licence declarations disagree: info.xml '$lic_xml' vs composer.json '$lic_composer'"
fi

if [ -n "$want_copyright" ] && [ -f LICENSE.txt ] && ! grep -qF "$want_copyright" LICENSE.txt; then
  fail "LICENSE.txt does not name the copyright holder '$want_copyright' from .ckconform"
fi

if [ -n "$want_npm" ] && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  for manifest in $(git ls-files '*package.json' | grep -v node_modules); do
    have=$(sed -n 's/.*"license"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$manifest" | head -1)
    [ "$(lc "$have")" = "$(lc "$want_npm")" ] \
      || fail "$manifest license is '${have:-unset}', .ckconform expects '$want_npm'"
  done
fi

# floating tags in CI: ':latest' and 'releases/latest/download' make a green run
# unreproducible and a red one unattributable.
if ls .github/workflows/*.yml >/dev/null 2>&1; then
  floating=$(grep -n 'image:.*:latest\|releases/latest/download' .github/workflows/*.yml 2>/dev/null | head -3)
  [ -n "$floating" ] && warn "CI pins nothing (floating :latest): $(echo "$floating" | head -1 | cut -c1-70)"
fi

# lockfiles: a tracked manifest without a tracked lockfile means nobody can
# reproduce a build — least of all the CI run that shipped the bundle. The
# frozen install form is what makes the lockfile binding, so check it too.
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  for manifest in $(git ls-files '*package.json' | grep -v node_modules); do
    dir=$(dirname "$manifest")
    found=""
    for lock in package-lock.json yarn.lock pnpm-lock.yaml bun.lock bun.lockb; do
      git ls-files --error-unmatch "${dir}/${lock}" >/dev/null 2>&1 && found="$lock"
    done
    [ -n "$found" ] || fail "$manifest has no tracked lockfile (builds are unreproducible)"
  done
  git ls-files composer.json >/dev/null 2>&1 \
    && [ -n "$(sed -n '/"require"/,/}/p' composer.json 2>/dev/null | grep -vE '"(require|php)"|^\s*[}{]')" ] \
    && ! git ls-files --error-unmatch composer.lock >/dev/null 2>&1 \
    && fail "composer.json declares dependencies but composer.lock is not tracked"
  for ignored in package-lock.json yarn.lock pnpm-lock.yaml bun.lock composer.lock; do
    grep -qE "^/?${ignored//./\\.}$|/${ignored//./\\.}$" .gitignore 2>/dev/null \
      && fail ".gitignore excludes $ignored — lockfiles belong in the repo"
  done
  if ls .github/workflows/*.yml >/dev/null 2>&1; then
    grep -qE '(^|\s)npm install(\s|$)' .github/workflows/*.yml 2>/dev/null \
      && warn "CI runs 'npm install' — use 'npm ci' so the lockfile is binding"
  fi
fi

# committed artifacts
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  for bad in .phpunit.result.cache node_modules vendor; do
    if git ls-files --error-unmatch "$bad" >/dev/null 2>&1 \
      || [ -n "$(git ls-files "$bad/" "*/$bad/*" 2>/dev/null | head -1)" ]; then
      fail "build/cache artifact committed: $bad"
    fi
  done
  [ -f .gitignore ] || fail "no .gitignore (build output and vendor/ land in git)"
fi

echo
echo "ckconform: $fails failure(s), $warns warning(s)"
[ "$fails" -eq 0 ]
