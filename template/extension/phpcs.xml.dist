<?xml version="1.0"?>
<ruleset name="__EXTKEY__">
  <description>Project layer over the bundled CiviKitchen standard.</description>

  <rule ref="CiviKitchen"/>

  <file>.</file>
  <arg name="extensions" value="php"/>

  <!-- Generated / vendored code is not ours to style. -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/dist/*</exclude-pattern>
  <exclude-pattern>*.civix.php</exclude-pattern>
  <exclude-pattern>*/CRM/*/DAO/*</exclude-pattern>
</ruleset>
