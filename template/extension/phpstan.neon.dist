parameters:
	level: 10
	# PHPDoc array shapes (APIv4 rows, decoded JSON) describe what the data
	# IS, but defensive runtime checks (is_array on decoded JSON) must not be
	# reported as redundant because of them. Also: PEAR-era signatures lie in
	# their PHPDocs (a documented "array" can be a PEAR_Error).
	treatPhpDocTypesAsCertain: false
	paths:
		- Civi
		- CRM
		- managed
		- __EXTKEY__.php
	excludePaths:
		analyse:
			# civix-generated stubs; the DAO base class is created at runtime
			- CRM/*/DAO/*
			- CRM/*/BAO/*
	scanFiles:
		- __EXTKEY__.civix.php
	# scanDirectories:
	#	# Core component extensions live off the classloader path — add the
	#	# ones whose types you touch, e.g.:
	#	# - /var/www/html/core/ext/civi_mail
	#	# - /var/www/html/core/ext/flexmailer/src
	bootstrapFiles:
		- phpstanBootstrap.php
	# ignoreErrors: only ever narrowly scoped (identifier + path + count) and
	# carrying a comment that says WHY the report is wrong — never blanket
	# patterns, never a baseline file.
